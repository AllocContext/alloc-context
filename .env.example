# Copy to .env in this directory (gitignored). Never commit the live file.
#
# Used by: ingest, status, scripts/local-up.sh
# Cursor stdio MCP reads config/config.yaml + SQLite; run ingest to refresh cache.

ALLOC_CONTEXT_CONFIG=/absolute/path/to/alloc-context/config/config.yaml
ALLOC_CONTEXT_DB=/absolute/path/to/alloc-context/state/alloccontext.db

# Read-only exchange keys (ingest portfolio snapshots)
KRAKEN_API_KEY=
KRAKEN_API_SECRET=
COINBASE_API_KEY=
COINBASE_API_SECRET=

# Optional macro / market feed keys
FRED_API_KEY=
FINNHUB_API_KEY=
COINGECKO_API_KEY=
COINMARKETCAP_API_KEY=
SOSOVALUE_API_KEY=

# Optional EVM wallet ingest (config enables onchain_cycle)
ALCHEMY_API_KEY=
ETHERSCAN_API_KEY=
