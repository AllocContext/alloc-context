# Copy to .env — never commit.

# Config
ALLOC_CONTEXT_CONFIG=config/config.yaml
ALLOC_CONTEXT_DB=state/alloccontext.db

# Kraken (read-only API key)
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Kalshi (optional — public market endpoints work without keys for sentiment)
KALSHI_API_KEY=
KALSHI_API_SECRET=

# Macro calendar (optional free API keys — static YAML works without keys)
FINNHUB_API_KEY=
FMP_API_KEY=

# ETF flows — free demo tier at https://openapi.sosovalue.com
SOSOVALUE_API_KEY=

# CoinGecko (keyless works; demo key optional for higher limits)
COINGECKO_API_KEY=

# CoinMarketCap (free Basic plan — required for CMC ingest)
COINMARKETCAP_API_KEY=

# FRED macro levels (free key at https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# LLM
OPENAI_API_KEY=

# Email delivery (Resend — HTTPS)
RESEND_API_KEY=
RESEND_FROM="AllocContext <onboarding@resend.dev>"
EMAIL_TO=
