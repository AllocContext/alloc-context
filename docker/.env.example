# Copy to .env in this directory — never commit .env
#
# Enable matching sources in config.yaml (ingest.sources) after adding keys
# below. See docs/docker-self-host.md.

# Exchanges (enable kraken and/or coinbase + exchanges.*.enabled in config)
# KRAKEN_API_KEY=
# KRAKEN_API_SECRET=
# COINBASE_API_KEY=
# COINBASE_API_SECRET=

# Data feeds (enable matching ingest.sources flags in config.yaml)
# FRED_API_KEY=          # fred: true
# FINNHUB_API_KEY=       # macro_calendar feeds (finnhub_enabled: true)
# FMP_API_KEY=           # macro_calendar feeds (fmp_enabled: true)
# COINGECKO_API_KEY=     # coingecko: true (demo works without key if use_demo_key)
# COINMARKETCAP_API_KEY= # coinmarketcap: true
# SOSOVALUE_API_KEY=     # etf_flows: true + sosovalue_enabled: true

# Keyless sources — flip in config.yaml only (no env var):
# fear_greed, kalshi, macro_calendar (static calendar)
