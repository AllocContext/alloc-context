# Copy to .env in this directory — never commit .env
#
# Keyless feeds (Kalshi, Fear & Greed, macro calendar, CoinGecko demo) are
# enabled in config.yaml by default. Add keys below and flip matching
# ingest.sources flags to enable keyed optional feeds.
# See docs/docker-self-host.md.

# Exchanges (enable kraken and/or coinbase + exchanges.*.enabled in config)
# KRAKEN_API_KEY=
# KRAKEN_API_SECRET=
# COINBASE_API_KEY=
# COINBASE_API_SECRET=

# Keyed optional feeds (enable matching ingest.sources flags in config.yaml)
# FRED_API_KEY=          # fred: true
# FINNHUB_API_KEY=       # macro_calendar + finnhub_enabled: true
# FMP_API_KEY=           # macro_calendar + fmp_enabled: true
# COINMARKETCAP_API_KEY= # coinmarketcap: true
# SOSOVALUE_API_KEY=     # etf_flows: true + sosovalue_enabled: true
